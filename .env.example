# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="postgresql://user:password@localhost:5432/envichips_db?schema=public"
AUTH_SECRET="your-auth-secret-here"
NEXTAUTH_SECRET="your-nextauth-secret-here"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Seed configuration
SEED_MODE=development   # Set to "production" for production bootstrap
ADMIN_EMAIL=julianflorez2019@gmail.com
ADMIN_PASSWORD=admin123  # Change after first login
